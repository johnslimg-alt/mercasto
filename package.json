{
  "name": "mercasto",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:server": "node server/index.js",
    "smoke:prod": "bash scripts/production-smoke.sh",
    "smoke:security": "bash scripts/security-probes.sh",
    "smoke:routes": "bash scripts/listing-route-smoke.sh",
    "smoke:copy": "bash scripts/public-copy-scan.sh",
    "smoke:all": "npm run check:scripts && npm run smoke:prod && npm run smoke:security && npm run smoke:routes && npm run smoke:copy",
    "smoke:full": "npm run smoke:all && npm run maintenance:precheck",
    "verify:quick": "npm run smoke:all",
    "verify:prod": "npm run smoke:full",
    "maintenance:precheck": "bash scripts/os-maintenance-precheck.sh",
    "smoke": "npm run smoke:prod",
    "check:scripts": "find scripts -type f -name '*.sh' -print0 | xargs -0 -r -n1 bash -n",
    "check:recovery": "node scripts/check-recovery-guards.mjs"
  },
  "dependencies": {
    "@sentry/react": "^10.49.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "laravel-echo": "^2.3.4",
    "lucide-react": "^1.8.0",
    "pusher-js": "^8.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.2.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tailwindcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "vite": "^8.0.9"
  }
}
