GEMINI_REST_URL=
GEMINI_API_KEY=
PORT=5000

# Example for Google Vertex/Generative API (replace with your provider's full URL):
# GEMINI_REST_URL=https://us-central1-aiplatform.googleapis.com/v1/projects/PROJECT/locations/LOCATION/models/MODEL:predict
# GEMINI_API_KEY=ya29....

# Marketing analytics / pixels
# Keep empty to disable a vendor. IDs are public tag identifiers, not API secrets.
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_VERBOSE=false
VITE_META_PIXEL_ID=
VITE_MICROSOFT_UET_TAG_ID=
VITE_CLARITY_PROJECT_ID=

# Grafana monitoring dashboard (only used with --profile monitoring)
GRAFANA_PASSWORD=

# Laravel Echo / Reverb WebSocket (for frontend)
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=mercasto.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
