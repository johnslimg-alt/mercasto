# Mercasto production environment template
# Copy values into the real production environment manager only.
# Do not commit live operational values.

APP_ENV=production
APP_DEBUG=false
APP_URL=https://mercasto.com

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_CLIENT=phpredis

FILESYSTEM_DISK=public
